<?xml version="1.0"?>
<ruleset name="WP Multisite Internal SSO">
  <description>WordPress Coding Standards for WP Multisite Internal SSO.</description>

  <file>./</file>

  <exclude-pattern>*/vendor/*</exclude-pattern>
  <exclude-pattern>*/node_modules/*</exclude-pattern>
  <exclude-pattern>*/.git/*</exclude-pattern>
  <exclude-pattern>*/.git.nosync/*</exclude-pattern>
  <exclude-pattern>*/zips/*</exclude-pattern>
  <exclude-pattern>*/.claude/*</exclude-pattern>
  <exclude-pattern>*/tests/*</exclude-pattern>
  <exclude-pattern>*/assets/wporg/*</exclude-pattern>

  <rule ref="WordPress" />
  <rule ref="WordPress-Extra" />
  <rule ref="WordPress-Docs" />

  <rule ref="WordPress">
    <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
    <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
  </rule>
  <rule ref="WordPress-Extra">
    <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
    <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
  </rule>

  <!--
    Staged enforcement (inherited v0.1.13 codebase): the i18n sniff stays
    silenced until MSSO-5 lands the .pot + translator-comment fixes and removes
    this block. Security sniffs were re-enabled in MSSO-4.
  -->
  <rule ref="WordPress.WP.I18n">
    <severity>0</severity>
  </rule>

  <!-- PHP compatibility floor (matches "Requires PHP: 8.1"). -->
  <config name="testVersion" value="8.1-"/>
  <rule ref="PHPCompatibilityWP" />

  <!-- WordPress version floor. -->
  <config name="minimum_supported_wp_version" value="6.0"/>

  <!-- Gate on errors; warnings remain visible but do not fail the build. -->
  <config name="ignore_warnings_on_exit" value="1"/>

  <arg name="basepath" value="."/>
  <arg name="colors"/>
  <arg name="extensions" value="php"/>
  <arg value="ps"/>
</ruleset>
