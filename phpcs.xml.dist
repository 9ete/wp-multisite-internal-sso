<?xml version="1.0"?>
<ruleset name="WP Multisite Internal SSO">
  <description>WordPress Coding Standards for WP Multisite Internal SSO.</description>

  <file>./</file>

  <exclude-pattern>*/vendor/*</exclude-pattern>
  <exclude-pattern>*/node_modules/*</exclude-pattern>
  <exclude-pattern>*/.git/*</exclude-pattern>
  <exclude-pattern>*/.git.nosync/*</exclude-pattern>
  <exclude-pattern>*/zips/*</exclude-pattern>
  <exclude-pattern>*/.claude/*</exclude-pattern>
  <exclude-pattern>*/tests/*</exclude-pattern>
  <exclude-pattern>*/assets/wporg/*</exclude-pattern>

  <rule ref="WordPress" />
  <rule ref="WordPress-Extra" />
  <rule ref="WordPress-Docs" />

  <rule ref="WordPress">
    <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
    <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
  </rule>
  <rule ref="WordPress-Extra">
    <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
    <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
  </rule>

  <!--
    Staged enforcement (inherited v0.1.13 codebase).
    These sniffs are temporarily silenced so `composer lint` stays green per
    commit while the remediation lands in its dedicated ticket. Each ticket
    below REMOVES its block and drives the findings to zero before merge:
      - WordPress.Security.*  -> MSSO-4 (security audit: sanitize/escape/nonce/caps)
      - WordPress.WP.I18n     -> MSSO-5 (i18n audit + .pot)
    New code written between now and those tickets still follows the practice;
    MSSO-4/MSSO-5 re-enable the automated gate to verify the whole tree.
  -->
  <rule ref="WordPress.Security.ValidatedSanitizedInput">
    <severity>0</severity>
  </rule>
  <rule ref="WordPress.Security.EscapeOutput">
    <severity>0</severity>
  </rule>
  <rule ref="WordPress.WP.I18n">
    <severity>0</severity>
  </rule>

  <!-- PHP compatibility floor (matches "Requires PHP: 8.1"). -->
  <config name="testVersion" value="8.1-"/>
  <rule ref="PHPCompatibilityWP" />

  <!-- WordPress version floor. -->
  <config name="minimum_supported_wp_version" value="6.0"/>

  <!-- Gate on errors; warnings remain visible but do not fail the build. -->
  <config name="ignore_warnings_on_exit" value="1"/>

  <arg name="basepath" value="."/>
  <arg name="colors"/>
  <arg name="extensions" value="php"/>
  <arg value="ps"/>
</ruleset>
